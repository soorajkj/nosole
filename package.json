{
  "name": "nosole",
  "version": "0.0.0",
  "description": "A lightweight logger that keeps your console clean in production.",
  "type": "module",
  "author": "Sooraj Janardhanan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/soorajkj/nosole.git"
  },
  "keywords": [
    "logger",
    "console",
    "debug"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.6"
  }
}
